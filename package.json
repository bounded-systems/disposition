{
  "name": "@bounded-systems/disposition",
  "version": "0.1.0",
  "description": "Pure classifier mapping work-unit surface state to a disposition (ok/prune/repair/review)",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bounded-systems/disposition.git"
  },
  "homepage": "https://github.com/bounded-systems/disposition#readme",
  "bugs": {
    "url": "https://github.com/bounded-systems/disposition/issues"
  },
  "keywords": [
    "disposition",
    "classifier",
    "work-unit",
    "state",
    "zod"
  ],
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "bun run build"
  },
  "peerDependencies": {
    "zod": "^3.25.0 || ^4.0.0"
  }
}
